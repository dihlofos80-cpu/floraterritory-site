<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Блог — <%= content.siteTitle %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Полезные статьи о ландшафтном дизайне, озеленении участка, уходе за газоном и растениями в Ижевске и Удмуртии.">
  <meta name="keywords" content="блог озеленение, ландшафтный дизайн, статьи о саде, уход за газоном, растения для Удмуртии">
  <link rel="icon" type="image/png" href="/images/logo-new.png?v=2">
  <link rel="stylesheet" href="/main.css">
  <!-- Open Graph -->
  <meta property="og:title" content="Блог — <%= content.siteTitle %>">
  <meta property="og:description" content="Полезные статьи о ландшафтном дизайне и озеленении">
  <meta property="og:image" content="/images/logo-new.png">
  <meta property="og:url" content="https://floraterritory.ru/blog">
  <meta property="og:type" content="website">
  <!-- Микроразметка -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Блог Территории Флоры",
    "description": "Статьи о ландшафтном дизайне и озеленении",
    "url": "https://floraterritory.ru/blog"
  }
  </script>
</head>
<body>

<header class="scrolled">
  <div class="container">
    <div class="header-inner">
      <div class="logo">
        <a href="/">
          <img src="<%= content.logoPath || '/images/logo-new.webp' %>" alt="<%= content.siteTitle %> — логотип" style="height: 50px;">
        </a>
      </div>
      <div class="site-title"><a href="/" style="color: inherit; text-decoration: none;"><%= content.siteTitle %></a></div>
      <nav style="display:flex;gap:15px;">
        <a href="/" style="color:#222;text-decoration:none;font-size:14px;">Главная</a>
        <a href="/blog" style="color:#285428;font-weight:bold;font-size:14px;">Блог</a>
      </nav>
      <div class="header-contacts">
        <a href="tel:+<%= content.phone.replace(/[^0-9]/g, '') %>"><%= content.phone %></a>
        <a href="mailto:<%= content.email %>"><%= content.email %></a>
      </div>
    </div>
  </div>
</header>

<main>
  <section class="section" style="background: var(--bg-light); padding: 60px 0;">
    <div class="container">
      <h1 class="section-title">Полезные статьи</h1>
      <p class="section-subtitle">Советы по ландшафтному дизайну, озеленению и уходу за участком</p>
      
      <div class="blog-grid">
        <% if (content.blog && content.blog.length > 0) { %>
          <% content.blog.forEach(function(post) { %>
            <article class="blog-card">
              <% if (post.image) { %>
                <div class="blog-image" style="background-image: url('<%= post.image %>');"></div>
              <% } %>
              <div class="blog-content">
                <h3><%= post.title %></h3>
                <p class="blog-excerpt"><%= post.excerpt %></p>
                <a href="/blog/<%= post.slug %>" class="btn-outline">Читать далее</a>
              </div>
            </article>
          <% }); %>
        <% } else { %>
          <p>Статьи скоро появятся...</p>
        <% } %>
      </div>
    </div>
  </section>

  <section class="section" id="contacts" style="background: #f8f9f5;">
    <div class="container contacts-grid" style="background: #fff;">
      <div class="contact-info">
        <h2 class="section-title">Нужна консультация?</h2>
        <p>Расскажите о вашем участке — поможем с выбором решений.</p>
        <p><strong>Телефон:</strong> <a href="tel:+<%= content.phone.replace(/[^0-9]/g, '') %>"><%= content.phone %></a></p>
        <p><strong>Почта:</strong> <a href="mailto:<%= content.email %>"><%= content.email %></a></p>
      </div>
      <div class="contact-form">
        <form id="contactForm">
          <label for="name">Имя</label>
          <input id="name" type="text" name="name" placeholder="Ваше имя" required>
          <label for="phone">Телефон</label>
          <input id="phone" type="tel" name="phone" placeholder="+7 (___) ___-__-__" required>
          <label for="message">Вопрос</label>
          <textarea id="message" name="message" placeholder="Кратко о задаче"></textarea>
          <div class="consent-wrapper">
            <input type="checkbox" id="consent" name="consent" required>
            <label for="consent">Даю согласие на обработку <a href="/privacy-policy" target="_blank">персональных данных</a></label>
          </div>
          <button type="submit" class="btn-primary" style="width:100%;">Отправить</button>
        </form>
        <div id="formMessage" style="display:none;margin-top:10px;padding:10px;border-radius:4px;"></div>
      </div>
    </div>
  </section>
</main>

<footer style="background: #302d27; color: #cbc3b4; padding: 30px 0;">
  <div class="container" style="text-align: center;">
    <p>&copy; <%= new Date().getFullYear() %> <%= content.siteTitle %>. Все права защищены.</p>
    <p>Ижевск и Удмуртская Республика</p>
  </div>
</footer>

<script>
document.getElementById('contactForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const formData = new FormData(e.target);
  const data = Object.fromEntries(formData);
  const btn = e.target.querySelector('button');
  btn.disabled = true;
  btn.textContent = 'Отправка...';
  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(data)
    });
    const result = await res.json();
    const msg = document.getElementById('formMessage');
    msg.style.display = 'block';
    if (result.success) {
      msg.style.background = '#d4edda';
      msg.style.color = '#155724';
      msg.textContent = 'Спасибо! Заявка отправлена. Мы перезвоним.';
      e.target.reset();
    } else {
      msg.style.background = '#f8d7da';
      msg.style.color = '#721c24';
      msg.textContent = 'Ошибка. Попробуйте позже.';
    }
  } catch (err) {
    msg.style.display = 'block';
    msg.style.background = '#f8d7da';
    msg.textContent = 'Ошибка связи.';
  }
  btn.disabled = false;
  btn.textContent = 'Отправить заявку';
});
</script>

</body>
</html>