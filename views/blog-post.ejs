<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= post.title %> — Блог <%= content.siteTitle %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="<%= post.excerpt %>">
  <meta name="keywords" content="озеленение, ландшафтный дизайн, Ижевск, сад, газон, растения">
  <link rel="icon" type="image/png" href="/images/logo-new.png?v=2">
  <link rel="stylesheet" href="/main.css">
  <!-- Open Graph -->
  <meta property="og:title" content="<%= post.title %>">
  <meta property="og:description" content="<%= post.excerpt %>">
  <meta property="og:image" content="<%= post.image || '/images/logo-new.png' %>">
  <meta property="og:url" content="https://floraterritory.ru/blog/<%= post.slug %>">
  <meta property="og:type" content="article">
  <!-- Микроразметка Article -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "<%= post.title %>",
    "description": "<%= post.excerpt %>",
    "image": "<%= post.image || 'https://floraterritory.ru/images/logo-new.png' %>",
    "author": {
      "@type": "Organization",
      "name": "Территория Флоры"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Территория Флоры",
      "logo": {
        "@type": "ImageObject",
        "url": "https://floraterritory.ru/images/logo-new.png"
      }
    }
  }
  </script>
</head>
<body>

<header class="scrolled">
  <div class="container">
    <div class="header-inner">
      <div class="logo">
        <a href="/">
          <img src="<%= content.logoPath || '/images/logo-new.webp' %>" alt="<%= content.siteTitle %>" style="height: 50px;">
        </a>
      </div>
      <div class="site-title"><a href="/" style="color: inherit; text-decoration: none;"><%= content.siteTitle %></a></div>
      <div class="header-contacts">
        <a href="tel:+<%= content.phone.replace(/[^0-9]/g, '') %>"><%= content.phone %></a>
      </div>
    </div>
  </div>
</header>

<main>
  <section class="section" style="background: var(--bg-light); padding: 60px 0;">
    <div class="container">
      <a href="/blog" style="color: #285428; text-decoration: none; display: inline-block; margin-bottom: 20px;">← К статьям</a>
      
      <article class="blog-post">
        <% if (post.image) { %>
          <div class="blog-post-image" style="background-image: url('<%= post.image %>');"></div>
        <% } %>
        <h1><%= post.title %></h1>
        <div class="blog-post-content">
          <%- post.content.replace(/\n\n/g, '</p><p>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') %>
        </div>
      </article>
      
      <div style="margin-top: 40px;">
        <a href="/blog" class="btn-outline">Другие статьи</a>
      </div>
    </div>
  </section>

  <section class="section" id="contacts" style="background: #f8f9f5;">
    <div class="container contacts-grid" style="background: #fff;">
      <div class="contact-info">
        <h2 class="section-title">Нужна консультация?</h2>
        <p>Расскажите о вашем участке — поможем с выбором решений.</p>
        <p><strong>Телефон:</strong> <a href="tel:+<%= content.phone.replace(/[^0-9]/g, '') %>"><%= content.phone %></a></p>
      </div>
      <div class="contact-form">
        <form id="contactForm">
          <label for="name">Имя</label>
          <input id="name" type="text" name="name" placeholder="Ваше имя" required>
          <label for="phone">Телефон</label>
          <input id="phone" type="tel" name="phone" placeholder="+7 (___) ___-__-__" required>
          <button type="submit" class="btn-primary" style="width:100%;">Отправить</button>
        </form>
      </div>
    </div>
  </section>
</main>

<footer style="background: #302d27; color: #cbc3b4; padding: 30px 0;">
  <div class="container" style="text-align: center;">
    <p>&copy; <%= new Date().getFullYear() %> <%= content.siteTitle %></p>
  </div>
</footer>

</body>
</html>